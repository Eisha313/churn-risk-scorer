# Churn Risk Scorer Configuration
# Copy this file to .env and modify as needed

# Enable debug mode (true/false)
CHURN_DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
CHURN_LOG_LEVEL=INFO

# Model filename (stored in models/ directory)
CHURN_MODEL_NAME=churn_model.pkl

# Random seed for reproducibility
CHURN_RANDOM_SEED=42

# Test set size for train/test split (0.0 to 1.0)
CHURN_TEST_SIZE=0.2

# Maximum iterations for logistic regression
CHURN_MAX_ITER=1000
